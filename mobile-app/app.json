{
  "expo": {
    "name": "PulseConnect",
    "slug": "pulseconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pulseconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sumeet.chatwithfriends",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Allow PulseConnect to access your camera for video calls.",
        "NSMicrophoneUsageDescription": "Allow PulseConnect to access your microphone for calls.",
        "NSPhotoLibraryUsageDescription": "Allow PulseConnect to access your photos to share images.",
        "NSLocationWhenInUseUsageDescription": "Allow PulseConnect to use your location to enhance your experience.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow PulseConnect to use your location for app features."
      }
    },
    "android": {
      "package": "com.sumeet.chatwithfriends",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PulseConnect to use your location."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow PulseConnect to access your microphone.",
          "cameraPermission": "Allow PulseConnect to access your camera for video calls."
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ab42a0a8-408a-4523-a905-d9f6cea9b5ed"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "sumeet97"
  }
}
